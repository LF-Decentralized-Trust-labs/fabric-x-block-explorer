# Local `npm run dev` config. Next.js auto-loads .env / .env.local from this dir.
# (For Docker/Compose, configure these in the repo-root .env instead.)

# Backend the /api proxy forwards to, read at runtime by app/api/[...path]/route.ts.
BACKEND_URL=http://localhost:8080

# Backend URL shown in the UI. NEXT_PUBLIC_* is inlined at build time, not runtime.
NEXT_PUBLIC_BACKEND_DISPLAY_URL=http://localhost:8080
